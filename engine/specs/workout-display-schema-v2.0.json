{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deterministic Workout Display Response v2.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "session_name",
    "training_focus",
    "session_length",
    "equipment_mode",
    "program_week_key",
    "weekly_strategy",
    "coach_banner",
    "progression_focus",
    "volume_mode",
    "deload_flag",
    "include_abs",
    "exercise_cards"
  ],
  "properties": {
    "session_id": {
      "type": "string"
    },
    "session_name": {
      "type": "string"
    },
    "training_focus": {
      "type": "string",
      "enum": [
        "chest_triceps",
        "back_biceps",
        "legs_shoulders",
        "abs_core"
      ]
    },
    "session_length": {
      "type": "string",
      "enum": [
        "short",
        "medium",
        "long"
      ]
    },
    "equipment_mode": {
      "type": "string",
      "enum": [
        "full_gym",
        "dumbbell_only",
        "machine_only",
        "bodyweight_only",
        "hotel_gym"
      ]
    },
    "program_week_key": {
      "type": "string"
    },
    "weekly_strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readiness_status",
        "weekly_strategy_label",
        "trigger_reason",
        "coach_notes"
      ],
      "properties": {
        "readiness_status": {
          "type": "string"
        },
        "weekly_strategy_label": {
          "type": "string"
        },
        "trigger_reason": {
          "type": "string"
        },
        "coach_notes": {
          "type": "string"
        }
      }
    },
    "coach_banner": {
      "type": "string"
    },
    "progression_focus": {
      "type": "string"
    },
    "volume_mode": {
      "type": "string"
    },
    "deload_flag": {
      "type": "boolean"
    },
    "include_abs": {
      "type": "boolean"
    },
    "exercise_cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "card_id",
          "slot_id",
          "slot_family",
          "order_index",
          "exercise_id",
          "name",
          "sets",
          "reps",
          "focus_area",
          "movement_type",
          "equipment",
          "swap_enabled",
          "allowed_swap_ids"
        ],
        "properties": {
          "card_id": {
            "type": "string"
          },
          "slot_id": {
            "type": "string"
          },
          "slot_family": {
            "type": "string"
          },
          "order_index": {
            "type": "integer"
          },
          "exercise_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "sets": {
            "type": "string"
          },
          "reps": {
            "type": "string"
          },
          "focus_area": {
            "type": "string"
          },
          "movement_type": {
            "type": "string"
          },
          "equipment": {
            "type": "string"
          },
          "cue": {
            "type": [
              "string",
              "null"
            ]
          },
          "progression_note": {
            "type": [
              "string",
              "null"
            ]
          },
          "media_key": {
            "type": [
              "string",
              "null"
            ]
          },
          "swap_enabled": {
            "type": "boolean"
          },
          "allowed_swap_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "swap_context": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": false,
            "properties": {
              "same_slot_required": {
                "type": "boolean"
              },
              "same_equipment_mode_required": {
                "type": "boolean"
              },
              "reason_if_locked": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        }
      }
    }
  }
}
